# Node modules folder
node_modules/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage/

# nyc test coverage
.nyc_output/

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt/

# Bower dependency directory (if you use bower)
bower_components/

# dotenv environment variables file
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# PM2 process manager files
.pm2/

# IDE/editor specific files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS generated files
.DS_Store
Thumbs.db

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Build output directory (if you use a build step)
dist/
build/

# TypeScript cache
*.tsbuildinfo

# Yarn Integrity file
.yarn-integrity

# Next.js build output
.next/

# Parcel-bundler cache (if you use Parcel)
.cache/

# Misc
*.tgz
